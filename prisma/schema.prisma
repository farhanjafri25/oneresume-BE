// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String?  // bcrypt hash — never returned in API responses (optional for OAuth users)
  createdAt DateTime @default(now())

  resumes Resume[]

  @@map("users")
}

model Resume {
  id        String   @id @default(uuid())
  userId    String
  title     String   @default("Master Resume")
  slug      String
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  variants Variant[]
  views    ViewLog[] // New relation for view tracking

  @@unique([userId, slug])
  @@map("resumes")
}

model Variant {
  id        String  @id @default(uuid())
  resumeId  String
  slug      String  // e.g. "default", "frontend", "backend"
  isDefault Boolean @default(false)

  resume   Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  versions Version[]
  views    ViewLog[] // New relation for view tracking

  // Each slug must be unique within a resume
  @@unique([resumeId, slug])
  @@map("variants")
}

model Version {
  id            String   @id @default(uuid())
  variantId     String
  versionNumber Int      // auto-incremented per variant
  fileUrl       String   // UploadThing file URL
  publicId      String   // UploadThing file key
  createdAt     DateTime @default(now())

  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  // Ensure version numbers are unique per variant
  @@unique([variantId, versionNumber])
  @@map("versions")
}

model ViewLog {
  id            String   @id @default(uuid())
  resumeId      String
  variantId     String
  versionNumber Int
  ipAddress     String?
  country       String?
  userAgent     String?
  referer       String?
  label         String?  // Custom application label: e.g., "Google - Frontend"
  viewedAt      DateTime @default(now())

  resume  Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([resumeId, viewedAt])
  @@map("view_logs")
}
